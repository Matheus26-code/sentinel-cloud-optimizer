# =============================================================
# Template de variáveis de ambiente — Sentinel Cloud Optimizer
# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NÃO deve ser commitado (.gitignore).
# =============================================================

# ---- PostgreSQL (docker-compose) ----
POSTGRES_USER=admin
POSTGRES_PASSWORD=SUBSTITUA_AQUI
POSTGRES_DB=sentinel_cloud

# ---- Spring Boot — desenvolvimento local sem Docker ----
# Usado pelo application-dev.properties quando rodando fora do Docker.
# Dentro do Docker, o docker-compose sobrescreve com SPRING_DATASOURCE_*
DATABASE_URL=jdbc:postgresql://localhost:5433/sentinel_cloud
DB_USERNAME=admin
DB_PASSWORD=SUBSTITUA_AQUI
SPRING_PROFILES_ACTIVE=dev

# ---- Spring Boot — produção (AWS EC2) ----
# Configure estas variáveis na EC2 ou no systemd service:
# DATABASE_URL=jdbc:postgresql://<rds-endpoint>:5432/sentinel_cloud
# DB_USERNAME=sentinel_admin
# DB_PASSWORD=<senha-forte>
# SPRING_PROFILES_ACTIVE=prod
# BUDGET_ALERT_LIMIT=100.0
# CORS_ALLOWED_ORIGINS=http://<ip-ec2>:8080

# ---- Python Collector ----
# URL da API Java. Em dev: localhost. Em prod: IP da EC2.
API_URL=http://localhost:8080/api/costs
